# Database (PostgreSQL with pgvector extension)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_mr_reviewer

# JWT session secret (generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
JWT_SECRET=your_jwt_secret_min_32_chars_long

# Master encryption key for AES-256-GCM (must be exactly 64 hex characters = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This is the ONLY secret stored server-side. GitLab PATs are provided per-user
# via the UI and encrypted with this key before storage.
MASTER_ENCRYPTION_KEY=your_64_hex_char_encryption_key_here_1234567890abcdef1234567890abcdef

# Redis (for BullMQ repo indexing queue)
REDIS_URL=redis://localhost:6379

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# OpenAI API (required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI Models (optional — defaults shown)
# OPENAI_REVIEW_MODEL=gpt-4o-mini
# OPENAI_DEEP_REVIEW_MODEL=gpt-4.1
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_MAX_CONCURRENCY=2
# OPENAI_TIMEOUT=120000
